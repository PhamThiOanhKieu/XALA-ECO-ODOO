<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_xala_employee_map_form" model="ir.ui.view">
        <field name="name">xala.employee.map.form</field>
        <field name="model">xala.employee.map</field>
        <field name="arch" type="xml">
            <form string="Bản đồ Giám sát" create="false" edit="false" delete="false">
                <style>
                    .o_control_panel { display: none !important; }
                </style>
                <sheet style="max-width: 100% !important; width: 100% !important; padding: 0 !important; margin: 0 !important;">
                    <div class="oe_title" style="padding: 15px 20px 5px 20px; background-color: #ffffff; border-bottom: 1px solid #dee2e6;">
                        <h1 style="color: #0f172a; font-size: 24px; font-weight: 700; display: flex; align-items: center; gap: 10px;">
                            <i class="fa fa-map-marker" style="color: #ef4444;"/> BẢN ĐỒ GIÁM SÁT THU GOM RÁC REAL-TIME
                        </h1>
                        <p style="color: #64748b; font-size: 14px; margin-top: 4px;">Giám sát hành trình thực tế của nhân viên (chấm đỏ) và vị trí của các hộ dân/khách hàng (chấm xanh).</p>
                    </div>
                    
                    <div style="width: 100%; height: calc(100vh - 120px); min-height: 680px; overflow: hidden; position: relative;">
                        <iframe title="Map Monitoring" 
                                width="100%" 
                                height="100%" 
                                src="/xala_eco/map_view" 
                                frameborder="0" 
                                style="border: none; width: 100%; height: 100%;">
                        </iframe>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_xala_employee_map" model="ir.actions.act_window">
        <field name="name">Bản đồ giám sát</field>
        <field name="res_model">xala.employee.map</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>
</odoo>
