<odoo>
    <record id="view_xalaeco_dashboard_form" model="ir.ui.view">
        <field name="name">xalaeco.dashboard.form</field>
        <field name="model">xalaeco.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard XALA ECO" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <h1>Dashboard XALA ECO</h1>
                        <p>Trang tổng quan quản lý khách hàng, công nợ và doanh thu</p>
                    </div>

                    <group col="3">
                        <group string="Tổng khách hàng">
                            <field name="total_customers" readonly="1" nolabel="1"/>
                        </group>

                        <group string="Hợp đồng hiệu lực">
                            <field name="active_contracts" readonly="1" nolabel="1"/>
                        </group>

                        <group string="Hợp đồng sắp hết hạn">
                            <field name="near_expired_contracts" readonly="1" nolabel="1"/>
                        </group>
                    </group>

                    <group col="3">
                        <group string="Tổng phải thu">
                            <field name="total_expected" readonly="1" nolabel="1"/>
                        </group>

                        <group string="Doanh thu đã thu">
                            <field name="total_revenue" readonly="1" nolabel="1"/>
                        </group>

                        <group string="Tổng còn nợ">
                            <field name="total_debt" readonly="1" nolabel="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_xalaeco_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">xalaeco.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="xalaeco_dashboard_main"/>
    </record>
</odoo>