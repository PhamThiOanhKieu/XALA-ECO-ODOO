<odoo>
    <record id="view_xalaeco_payment_tree" model="ir.ui.view">
        <field name="name">xalaeco.payment.tree</field>
        <field name="model">xalaeco.payment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="billing_id"/>
                <field name="amount_due"/>
                <field name="amount_paid"/>
                <field name="debt_amount"/>
                <field name="payment_method"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_xalaeco_payment_form" model="ir.ui.view">
        <field name="name">xalaeco.payment.form</field>
        <field name="model">xalaeco.payment</field>
        <field name="arch" type="xml">
            <form string="Thanh toán QR">
                <header>
                    <button name="action_confirm_paid"
                            string="Xác nhận đã thu"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_reset_unpaid"
                            string="Đưa về chưa thanh toán"
                            type="object"
                            class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="unpaid,partial,paid"/>
                    
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>

                    <group>
                        <group string="Thông tin thanh toán">
                            <field name="billing_id"/>
                            <field name="contract_id"/>
                            <field name="customer_id"/>
                            <field name="payment_date"/>
                            <field name="payment_method"/>
                            <field name="bank_transaction_code"/>
                        </group>

                        <group string="Số tiền và công nợ">
                            <field name="amount_due"/>
                            <field name="amount_paid"/>
                            <field name="debt_amount"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="QR VietQR">
                            <group>
                                <group string="Thông tin ngân hàng">
                                    <field name="bank_code"/>
                                    <field name="bank_account"/>
                                    <field name="account_name"/>
                                    <field name="transfer_content"/>
                                    <field name="qr_url" widget="url"/>
                                </group>

                                <group string="Mã QR thanh toán">
                                    <field name="qr_image" widget="image" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Ghi chú đối soát">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_xalaeco_payment" model="ir.actions.act_window">
        <field name="name">Thanh toán QR</field>
        <field name="res_model">xalaeco.payment</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_xalaeco_debt" model="ir.actions.act_window">
        <field name="name">Công nợ</field>
        <field name="res_model">xalaeco.payment</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('debt_amount','>',0)]</field>
    </record>

    <record id="view_xalaeco_payment_graph" model="ir.ui.view">
        <field name="name">xalaeco.payment.graph</field>
        <field name="model">xalaeco.payment</field>
        <field name="arch" type="xml">
            <graph string="Báo cáo doanh thu" type="bar">
                <field name="billing_id"/>
                <field name="amount_paid" type="measure"/>
                <field name="debt_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_xalaeco_revenue_report" model="ir.actions.act_window">
        <field name="name">Báo cáo doanh thu</field>
        <field name="res_model">xalaeco.payment</field>
        <field name="view_mode">graph,tree,form</field>
    </record>
</odoo>