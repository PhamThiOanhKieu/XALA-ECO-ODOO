<odoo>

    <record id="view_xalaeco_billing_tree" model="ir.ui.view">
        <field name="name">xalaeco.billing.list</field>
        <field name="model">xalaeco.billing</field>
        <field name="arch" type="xml">
            <list> <field name="name"/>
                <field name="month"/>
                <field name="year"/>
                <field name="customer_count"/>
                <field name="total_expected"/>
                <field name="total_paid"/>
                <field name="total_debt"/>
                <field name="state"/>
            </list> </field>
    </record>

    <record id="view_xalaeco_billing_form" model="ir.ui.view">
        <field name="name">xalaeco.billing.form</field>
        <field name="model">xalaeco.billing</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_payments"
                            string="Sinh công nợ tháng này"
                            type="object"
                            class="btn-primary"/>

                    <button name="action_send_sms_notification"
                            string="Gửi thông báo thu phí"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'collecting'"/>

                    <button name="action_close_period"
                            string="Chốt kỳ thu phí"
                            type="object"
                            class="btn-secondary"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,collecting,closed"/>
                 </header>

                <sheet>
                    <group string="Thông tin kỳ thu phí">
                        <field name="name"/>
                        <field name="month"/>
                        <field name="year"/>
                    </group>

                    <group string="Tổng hợp doanh thu">
                        <field name="customer_count" readonly="1"/>
                        <field name="total_expected" readonly="1"/>
                        <field name="total_paid" readonly="1"/>
                        <field name="total_debt" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Danh sách thanh toán được sinh tự động">
                            <field name="payment_ids" readonly="1">
                                <list> <field name="name"/>
                                    <field name="customer_id"/>
                                    <field name="contract_id"/>
                                    <field name="amount_due"/>
                                    <field name="amount_paid"/>
                                    <field name="debt_amount"/>
                                    <field name="state"/>
                                </list> </field>
                        </page>
                    </notebook>
                 </sheet>

                 <chatter/>

            </form>
        </field>
    </record>

    <record id="action_xalaeco_billing" model="ir.actions.act_window">
        <field name="name">Kỳ thu phí</field>
        <field name="res_model">xalaeco.billing</field>
        <field name="view_mode">list,form</field> </record>

</odoo>